{
  "format": "engraphis-railway-template-composer-source/v1",
  "name": "Engraphis Free Customer Node",
  "description": "Free single-user Engraphis memory node with optional clients for official hosted Pro and Team services.",
  "source": {
    "repository": "https://github.com/Coding-Dev-Tools/engraphis",
    "branch": "main",
    "dockerfile": "Dockerfile"
  },
  "service": {
    "healthcheck": "/api/ready",
    "public_domain": true,
    "volume": {
      "mount_path": "/data"
    }
  },
  "variables": {
    "ENGRAPHIS_SERVICE_MODE": {
      "value": "customer",
      "required": true
    },
    "ENGRAPHIS_DB_PATH": {
      "value": "/data/engraphis.db",
      "required": true
    },
    "ENGRAPHIS_STATE_DIR": {
      "value": "/data/.engraphis",
      "required": true
    },
    "ENGRAPHIS_API_TOKEN": {
      "value": "${{ secret(48) }}",
      "secret": true,
      "prompt": "Railway generates this bearer for the single-user customer node. Keep it private.",
      "required": true
    },
    "ENGRAPHIS_JSON_LOGS": {
      "value": "1",
      "required": true
    },
    "ENGRAPHIS_FORWARDED_ALLOW_IPS": {
      "value": "*",
      "required": true
    },
    "ENGRAPHIS_CLOUD_CONTROL_URL": {
      "value": "https://api.engraphis.com",
      "required": false
    },
    "ENGRAPHIS_CLOUD_COMPUTE_URL": {
      "value": "https://compute.engraphis.com",
      "required": false
    },
    "ENGRAPHIS_MANAGED_COMPUTE_CONSENT": {
      "value": "0",
      "prompt": "Change to 1 only after reviewing the managed snapshot upload boundary.",
      "required": false
    }
  }
}
